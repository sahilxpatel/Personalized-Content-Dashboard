      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "axios": "^1.16.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.16.0",
    "next": "14.2.33",
    "next-themes": "^0.4.6",
    "react": "^18",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18",
    "react-i18next": "^17.0.8",
    "react-redux": "^9.3.0",
    "redux-persist": "^6.0.0",
    "tailwind-merge": "^3.6.0"
